# Zingking Masala - Environment Variables Template

# Copy this file to .env.local and fill in your actual values

# ============================================
# DATABASE CONFIGURATION
# ============================================
MONGODB_URI=mongodb+srv://your_username:your_password@cluster0.mongodb.net/zingking_masala?retryWrites=true&w=majority

# ============================================
# JWT AUTHENTICATION
# ============================================
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production_min_32_chars
JWT_EXPIRE=7d

# ============================================
# EMAIL CONFIGURATION (Gmail / SendGrid / Nodemailer)
# ============================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password
SMTP_FROM=noreply@zingkingmasala.com

# For development, get Gmail App Password:
# 1. Go to myaccount.google.com/apppasswords
# 2. Generate password for "Mail" on "Windows Computer"
# 3. Use that 16-char password as SMTP_PASSWORD

# ============================================
# WHATSAPP INTEGRATION (Optional)
# ============================================
WHATSAPP_API_URL=https://api.whatsapp.com/send
WHATSAPP_PHONE=+91XXXXXXXXXX
WHATSAPP_BUSINESS_PHONE_ID=your_phone_id_from_meta

# ============================================
# PAYMENT GATEWAY (Optional - for future)
# ============================================
# Stripe
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxxxx
STRIPE_SECRET_KEY=sk_test_xxxxx

# Razorpay (Indian payment gateway)
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_xxxxx
RAZORPAY_KEY_SECRET=your_razorpay_secret

# ============================================
# GOOGLE MAPS & ANALYTICS (Optional)
# ============================================
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your_google_maps_api_key
NEXT_PUBLIC_GOOGLE_ANALYTICS_ID=G-XXXXXXXXXX

# ============================================
# ADMIN CREDENTIALS (Initial Setup)
# ============================================
# These are used only during initial setup via seeding script
ADMIN_EMAIL=admin@zingkingmasala.com
ADMIN_PASSWORD=password123  # Change this!

# ============================================
# APPLICATION CONFIGURATION
# ============================================
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=Zingking Masala

# ============================================
# ENVIRONMENT
# ============================================
NODE_ENV=development
# Options: development, staging, production

# ============================================
# LOGGING & DEBUGGING
# ============================================
DEBUG=false
LOG_LEVEL=info

# ============================================
# CORS & SECURITY
# ============================================
# Allowed origins for CORS (comma-separated)
ALLOWED_ORIGINS=http://localhost:3000,https://zingkingmasala.com

# ============================================
# THIRD-PARTY SERVICES (Optional)
# ============================================
# Sentry for error tracking
SENTRY_DSN=your_sentry_dsn

# Redis for caching (optional)
REDIS_URL=redis://localhost:6379

# AWS S3 for image storage (optional)
AWS_ACCESS_KEY_ID=your_aws_key
AWS_SECRET_ACCESS_KEY=your_aws_secret
AWS_S3_BUCKET=zingking-bucket
AWS_S3_REGION=ap-south-1

# ============================================
# PRODUCTION SECURITY (Production Only)
# ============================================
SECURE_COOKIES=true
SAME_SITE_COOKIES=strict
CSRF_TOKEN_ENABLED=true

# ============================================
# NOTES
# ============================================
# 1. NEVER commit .env.local to git
# 2. Use different tokens/keys for dev, staging, production
# 3. Rotate keys regularly in production
# 4. Use strong, random secrets (min 32 characters)
# 5. For MongoDB Atlas free tier: https://www.mongodb.com/cloud/atlas/register
# 6. For Gmail SMTP: Enable "Less secure app access" (or use App Password)
# 7. Keep .env.local secure: add to .gitignore
# 8. Use environment variables in all sensitive operations
# 9. Never log sensitive information
# 10. Document all environment variables and their purposes
